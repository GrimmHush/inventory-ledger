{
  "name": "inventory-ledger",
  "version": "0.1.0",
  "description": "An offline-first inventory service built around an append-only movement ledger. Typed REST API, a typed client SDK, and a fully tested sync core.",
  "type": "module",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "postinstall": "prisma generate",
    "dev": "tsx watch src/server/main.ts",
    "start": "tsx src/server/main.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "build": "tsup"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "dotenv": "^17.4.2",
    "express": "^4.19.2"
  },
  "devDependencies": {
    "@prisma/config": "^7.8.0",
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.0",
    "@types/supertest": "^6.0.2",
    "eslint": "^9.9.0",
    "prisma": "^7.8.0",
    "supertest": "^7.0.0",
    "tsup": "^8.2.4",
    "tsx": "^4.17.0",
    "typescript": "^5.5.4",
    "typescript-eslint": "^8.2.0",
    "vitest": "^4.1.9"
  }
}
