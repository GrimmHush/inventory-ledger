generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Item {
  id        String     @id
  sku       String     @unique
  name      String
  createdAt DateTime
  updatedAt DateTime
  // Denormalized stock cache, maintained transactionally on every write so that
  // listing items doesn't fold the whole movement log. Stock is still *derived*
  // from movements (the log is the source of truth); this column is the checkpoint.
  stock     Int        @default(0)
  movements Movement[]

  @@map("items")
}

model Movement {
  id         String   @id
  itemId     String
  type       String   // 'in', 'out', or 'adjust'
  quantity   Int
  reason     String?
  occurredAt DateTime
  
  item       Item     @relation(fields: [itemId], references: [id])

  // Backs the ledger keyset queries: filter by itemId, order by (occurredAt, id).
  // itemId is the leading column, so this also serves plain itemId lookups.
  @@index([itemId, occurredAt, id])
  @@map("movements")
}